rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🔥 TESTING MODE - ALL PUBLIC ACCESS
    // ⚠️ WARNING: Change these rules before production!
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

