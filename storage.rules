rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 🔥 TESTING MODE - ALL PUBLIC ACCESS
    // ⚠️ WARNING: Change these rules before production!
    
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}

